{
  "PalworldApi": {
    "BaseUrl": "http://localhost:8212",
    "Admin": {
      "Username": "admin"
    }
  },
  "Collector": {
    "PlayerLocationUpdateIntervalMs": 5000,
    "GameDataUpdateIntervalMs": 30000,
    "ServerSettingsUpdateIntervalMs": 3600000,
    "FailureRetryIntervalMs": 5000,
    "PalworldHealthCacheDurationMs": 5000
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
