ASPNETCORE_HTTP_PORTS=8080
DOTNET_ENVIRONMENT=Development
PalworldApi__BaseUrl=http://palworld:8212
PalworldApi__Admin__Username=admin
PalworldApi__Admin__Password=palmap-integration
PalmapIngest__Endpoint=http://host.docker.internal:5080/api/ingest/v1/snapshots
PalmapIngest__ClientId=replace-with-issued-client-id
PalmapIngest__ClientSecret=replace-with-issued-client-secret
# Public demonstration key only. Generate a unique 32-byte key and base64-encode it before real use.
PalmapIngest__PrivacyKey=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
PalmapIngest__AllowInsecureHttp=true
Collector__PlayerLocationUpdateIntervalMs=5000
Collector__GameDataUpdateIntervalMs=30000
Collector__ServerSettingsUpdateIntervalMs=3600000
Collector__FailureRetryIntervalMs=5000
Collector__PalworldHealthCacheDurationMs=5000
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
